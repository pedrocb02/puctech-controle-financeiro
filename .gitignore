# ==============================================================================
# DATA SCIENCE (NumPy e Pandas)
# ==============================================================================
# Arquivos de dados costumam ser muito pesados para o Git. 
# O ideal é salvá-los localmente ou em um storage (S3, Drive, etc.)
*.csv
*.xlsx
*.json
*.parquet
*.pkl
*.pickle
*.npy
*.npz

# Pastas comuns para guardar bases de dados locais
data/
datasets/
inputs/
outputs/

